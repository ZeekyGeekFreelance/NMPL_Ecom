{
  "name": "client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node ./scripts/run-next.js dev",
    "repo:sanity": "node ./scripts/repo-sanity-proxy.js",
    "env:check": "node ./scripts/validate-env.js",
    "build": "npm run repo:sanity && npm run env:check -- --production && node ./scripts/assert-determinism.js pre .next && node ./scripts/run-next.js build && node ./scripts/assert-determinism.js post .next",
    "start": "node ./scripts/run-next.js start",
    "lint": "next lint",
    "audit": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=22 <23"
  },
  "overrides": {
    "flatted": "3.4.2"
  },
  "dependencies": {
    "@apollo/client": "3.13.8",
    "@reduxjs/toolkit": "2.7.0",
    "@stripe/stripe-js": "7.3.0",
    "apexcharts": "4.7.0",
    "axios": "1.13.6",
    "date-fns": "4.1.0",
    "framer-motion": "12.9.4",
    "graphql": "16.11.0",
    "lodash": "4.17.23",
    "lucide-react": "0.483.0",
    "next": "15.5.14",
    "nprogress": "0.2.0",
    "react": "19.1.0",
    "react-apexcharts": "1.7.0",
    "react-dom": "19.1.0",
    "react-hook-form": "7.56.2",
    "react-redux": "9.2.0",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.5",
    "@tailwindcss/postcss": "4.1.5",
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.3",
    "eslint": "9.39.4",
    "eslint-config-next": "15.5.14",
    "tailwindcss": "4.1.5",
    "typescript": "5.8.3"
  }
}

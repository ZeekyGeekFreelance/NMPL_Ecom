NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
# Direct backend URL for SSR — not exposed to browser. In production set this
# when you have an internal service-to-service address available so SSR
# bypasses the public CDN/proxy. Falls back to NEXT_PUBLIC_API_URL if unset.
INTERNAL_API_URL=http://localhost:5000/api/v1
# Production build fails if NEXT_PUBLIC_API_URL points to localhost/127.0.0.1.
NEXT_PUBLIC_PLATFORM_NAME=NMPL
NEXT_PUBLIC_SUPPORT_EMAIL=support@nmpl.online
NEXT_PUBLIC_ENABLE_NATIVE_CONFIRM=false
# NEXT_PUBLIC_DEALER_CATALOG_POLL_MS=15000

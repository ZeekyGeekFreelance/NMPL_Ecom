# -------------------------
# API ENDPOINTS
# -------------------------
NEXT_PUBLIC_API_URL=         # Optional shared API base (without /api/v1 also supported)
NEXT_PUBLIC_API_URL_DEV=     # Dev API base (example: http://localhost:5000/api/v1)
NEXT_PUBLIC_API_URL_PROD=    # Prod API base (example: https://api.example.com/api/v1)

# -------------------------
# ENVIRONMENT
# -------------------------
NODE_ENV=                    # Environment mode (development | production)

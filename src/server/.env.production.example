# Production server environment template
# Copy this to src/server/.env.production locally, then load those values into Railway.
# Do not commit the real .env.production file.

NODE_ENV=production
# Script-only safeguard for destructive Prisma scripts such as seed/import.
DB_ENV=production
DOCKER_MODE=true
TRUST_PROXY=true
PORT=5000
PUBLIC_API_BASE_URL=https://api.nmpl.online

CLIENT_URL_DEV=http://localhost:3000
CLIENT_URL_PROD=https://nmpl.online
ALLOWED_ORIGINS=https://nmpl.online,https://www.nmpl.online

# Database
DATABASE_URL=postgresql://<neon_user>:<neon_password>@<neon_pooler_host>/<db_name>?sslmode=require&pgbouncer=true&connection_limit=20&pool_timeout=20
DIRECT_URL=postgresql://<neon_user>:<neon_password>@<neon_direct_host>/<db_name>?sslmode=require
DB_SSL_REQUIRED=true
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_TIMEOUT_MS=20000

# Redis
REDIS_ENABLED=true
REDIS_URL=redis://<username>:<password>@<redis_host>:<redis_port>
REDIS_NAMESPACE=ecommerce_prod
REDIS_PARITY_KEY=config-hash
REDIS_CONNECT_TIMEOUT_MS=5000

# Auth and emergency recovery
# Generate each secret with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
ACCESS_TOKEN_SECRET=<GENERATE_64_BYTE_HEX_SECRET>
REFRESH_TOKEN_SECRET=<GENERATE_64_BYTE_HEX_SECRET>
COOKIE_SECRET=<GENERATE_64_BYTE_HEX_SECRET>
SUPERADMIN_RESET_SECRET=<GENERATE_64_BYTE_HEX_SECRET>
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_ABS_TTL_SECONDS=604800
COOKIE_DOMAIN=.nmpl.online
COOKIE_SAMESITE=strict

# Security and runtime
HELMET_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https://res.cloudinary.com; connect-src 'self' https://api.nmpl.online
BODY_JSON_LIMIT=1mb
BODY_URLENCODED_LIMIT=1mb
MEMORY_UNHEALTHY_THRESHOLD_MB=2048
RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_OTP_MAX=15
RATE_LIMIT_ORDER_MAX=20

# Branding and operations
PLATFORM_NAME=NMPL
SUPPORT_EMAIL=support@nmpl.online
BILLING_NOTIFICATION_EMAILS=billing@nmpl.online
REPORTS_CACHE_TTL_SECONDS=300

# Delivery and pickup
BANGALORE_CITY_ALIASES=BANGALORE,BENGALURU
BANGALORE_DELIVERY_CHARGE=75
PICKUP_STORE_NAME=NMPL BLR
PICKUP_STORE_PHONE=+919036298679
PICKUP_STORE_LINE1=3rd Main Road, Chamrajpet
PICKUP_STORE_LANDMARK=Near Makkal-koota Garden
PICKUP_STORE_CITY=Bengaluru
PICKUP_STORE_STATE=Karnataka
PICKUP_STORE_COUNTRY=India
PICKUP_STORE_PINCODE=560004

# OTP and notifications
SMS_PROVIDER=TWILIO
TWILIO_ACCOUNT_SID=<YOUR_TWILIO_ACCOUNT_SID>
TWILIO_AUTH_TOKEN=<YOUR_TWILIO_AUTH_TOKEN>
TWILIO_FROM_NUMBER=<YOUR_TWILIO_PHONE_NUMBER>
REGISTRATION_OTP_EXPIRY_SECONDS=600
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=60
REGISTRATION_OTP_MAX_ATTEMPTS=5
REGISTRATION_PHONE_OTP_ENABLED=true

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=apikey
SMTP_PASS=<YOUR_SENDGRID_API_KEY>
EMAIL_SERVICE=smtp
EMAIL_FROM=noreply@nmpl.online
EMAIL_FROM_NAME=NMPL Support

# Payments
ENABLE_MOCK_PAYMENT=false
STRIPE_CURRENCY=inr
# STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
# STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>
RAZORPAY_MOCK_MODE=false
RAZORPAY_KEY_ID=<YOUR_RAZORPAY_KEY_ID>
RAZORPAY_KEY_SECRET=<YOUR_RAZORPAY_KEY_SECRET>

# Diagnostics
STRICT_BUILD_CHECKS=true
CLUSTER_PARITY_CHECK_ENABLED=true
MIXED_MODE_GUARD_ENABLED=false

# Media
# CLOUDINARY_CLOUD_NAME=<YOUR_CLOUDINARY_CLOUD_NAME>
# CLOUDINARY_API_KEY=<YOUR_CLOUDINARY_API_KEY>
# CLOUDINARY_API_SECRET=<YOUR_CLOUDINARY_API_SECRET>

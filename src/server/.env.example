# -------------------------
# DATABASE & SERVER CONFIG
# -------------------------
DATABASE_URL=                # PostgreSQL URL (example: postgresql://user:pass@127.0.0.1:5433/db_name for Docker DB)
NODE_ENV=                    # Environment mode (development | production)
PORT=                        # Backend port (example: 5000 in dev)
ORDER_RESERVATION_EXPIRY_HOURS= # Reservation hold window after quotation approval (default: 48)
ORDER_RESERVATION_SWEEP_SECONDS= # Quotation expiry worker interval in seconds (default: 60)
BANGALORE_DELIVERY_CHARGE=      # Optional Bangalore delivery flat fee (default: 75)
BANGALORE_CITY_ALIASES=         # Optional comma-separated aliases (default: BANGALORE,BENGALURU)

# -------------------------
# JWT & AUTH TOKENS
# -------------------------
ACCESS_TOKEN_SECRET=         # Secret key for signing access tokens
REFRESH_TOKEN_SECRET=        # Secret key for signing refresh tokens

# -------------------------
# SESSION & COOKIES
# -------------------------
SESSION_SECRET=              # Secret for server-side sessions
COOKIE_DOMAIN=               # Domain where cookies will be valid
ALLOWED_ORIGINS=             # Comma-separated list of allowed frontend origins
COOKIE_SECRET=               # Secret for cookie encryption

# -------------------------
# STRIPE PAYMENT GATEWAY
# -------------------------
STRIPE_PUBLIC_KEY=           # Stripe publishable API key (frontend use)
STRIPE_SECRET_KEY=           # Stripe secret API key (backend use)
STRIPE_WEBHOOK_SECRET=       # Stripe webhook signing secret
STRIPE_CURRENCY=             # Optional checkout currency code (default: inr)
ENABLE_MOCK_PAYMENT=         # Optional true/false; in non-production, auto-confirms quotation payment for local testing

# -------------------------
# PICKUP LOCATION (ORDER SNAPSHOT + INVOICE)
# -------------------------
PICKUP_STORE_NAME=           # Pickup location name (used in order snapshot/invoice for pickup mode)
PICKUP_STORE_PHONE=          # Pickup location contact phone
PICKUP_STORE_LINE1=          # Pickup address line 1
PICKUP_STORE_LINE2=          # Pickup address line 2 (optional)
PICKUP_STORE_LANDMARK=       # Pickup landmark (optional)
PICKUP_STORE_CITY=           # Pickup city
PICKUP_STORE_STATE=          # Pickup state
PICKUP_STORE_COUNTRY=        # Pickup country
PICKUP_STORE_PINCODE=        # Pickup pincode

# -------------------------
# REDIS
# -------------------------
REDIS_URL=                   # Redis connection URL for caching or sessions

# -------------------------
# GOOGLE OAUTH
# -------------------------
GOOGLE_CLIENT_ID=            # Google OAuth Client ID
GOOGLE_CLIENT_SECRET=        # Google OAuth Client Secret
GOOGLE_CALLBACK_URL_PROD=    # Google OAuth callback URL (production)
GOOGLE_CALLBACK_URL_DEV=     # Google OAuth callback URL (development, example: http://localhost:5100/api/v1/auth/google/callback)

# -------------------------
# FACEBOOK OAUTH
# -------------------------
FACEBOOK_APP_ID=             # Facebook App ID
FACEBOOK_APP_SECRET=         # Facebook App Secret
FACEBOOK_CALLBACK_URL_PROD=  # Facebook OAuth callback URL (production)
FACEBOOK_CALLBACK_URL_DEV=   # Facebook OAuth callback URL (development, example: http://localhost:5100/api/v1/auth/facebook/callback)

# -------------------------
# TWITTER OAUTH
# -------------------------
TWITTER_CONSUMER_KEY=        # Twitter API consumer key
TWITTER_CONSUMER_SECRET=     # Twitter API consumer secret
TWITTER_CALLBACK_URL_DEV=    # Twitter OAuth callback URL (development, example: http://localhost:5100/api/v1/auth/twitter/callback)
TWITTER_CALLBACK_URL_PROD=   # Twitter OAuth callback URL (production)

# -------------------------
# EMAIL SMTP CONFIG
# -------------------------
EMAIL_USER=                  # Fallback email username (used when SMTP_USER is not set)
EMAIL_PASS=                  # Fallback email password/app password (used when SMTP_PASS is not set)
EMAIL_SERVICE=               # Optional provider service name (default: gmail)
SMTP_HOST=                   # Optional SMTP host (preferred for production)
SMTP_PORT=                   # Optional SMTP port (default: 587, or 465 for secure)
SMTP_SECURE=                 # Optional true/false; defaults true for port 465
SMTP_USER=                   # Optional SMTP auth username
SMTP_PASS=                   # Optional SMTP auth password
EMAIL_FROM=                  # Optional custom from email address
EMAIL_FROM_NAME=             # Optional custom from display name

# -------------------------
# REGISTRATION OTP
# -------------------------
REGISTRATION_OTP_EXPIRY_SECONDS=            # Optional OTP expiry window (default: 600)
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=   # Optional resend cooldown (default: 60)
REGISTRATION_OTP_MAX_ATTEMPTS=              # Optional max OTP verify attempts before lock (default: 5)
REGISTRATION_PHONE_OTP_ENABLED=             # Optional true/false; default false (email OTP only)

# -------------------------
# SMS (PHONE OTP DELIVERY)
# -------------------------
SMS_PROVIDER=                # Optional: TWILIO or LOG (LOG is useful for local dev)
TWILIO_ACCOUNT_SID=          # Twilio Account SID for SMS delivery
TWILIO_AUTH_TOKEN=           # Twilio Auth Token for SMS delivery
TWILIO_FROM_NUMBER=          # Twilio sender phone number (E.164 format)

# -------------------------
# CLOUDINARY
# -------------------------
CLOUDINARY_CLOUD_NAME=       # Cloudinary cloud name
CLOUDINARY_API_KEY=          # Cloudinary API key
CLOUDINARY_API_SECRET=       # Cloudinary API secret

# -------------------------
# CLIENT URLS
# -------------------------
CLIENT_URL_PROD=             # Frontend URL (production)
CLIENT_URL_DEV=              # Frontend URL (development)

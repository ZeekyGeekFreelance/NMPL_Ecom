NODE_ENV=development
DOCKER_MODE=false
TRUST_PROXY=false
PORT=5001
PUBLIC_API_BASE_URL=http://localhost:5001

DATABASE_URL=postgresql://<db_user>:<db_password>@127.0.0.1:5433/<db_name>?schema=public&sslmode=disable&connection_limit=20&pool_timeout=20
DB_SSL_REQUIRED=false
DB_POOL_MAX=20
DB_IDLE_TIMEOUT_MS=30000
DB_POOL_TIMEOUT_MS=20000

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379
REDIS_NAMESPACE=ecommerce
REDIS_PARITY_KEY=config-hash
REDIS_CONNECT_TIMEOUT_MS=5000

ALLOWED_ORIGINS=http://localhost:3000
CLIENT_URL_DEV=http://localhost:3000
CLIENT_URL_PROD=https://example.com

SESSION_SECRET=replace_me
COOKIE_SECRET=replace_me
COOKIE_DOMAIN=localhost
COOKIE_SAMESITE=lax

ACCESS_TOKEN_SECRET=replace_me
REFRESH_TOKEN_SECRET=replace_me
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_ABS_TTL_SECONDS=86400

RATE_LIMIT_ENABLED=true
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_OTP_MAX=10
RATE_LIMIT_ORDER_MAX=8

HELMET_ENABLED=true
CSP_DIRECTIVES=default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self'
BODY_JSON_LIMIT=1mb
BODY_URLENCODED_LIMIT=1mb
MEMORY_UNHEALTHY_THRESHOLD_MB=512
STRICT_BUILD_CHECKS=true
CLUSTER_PARITY_CHECK_ENABLED=false
MIXED_MODE_GUARD_ENABLED=true
# Optional local Docker host DB port probe when running server outside Docker.
# If set, preflight aborts when Docker DB is active but DATABASE_URL points elsewhere.
DOCKER_DB_HOST_PORT=5433

PLATFORM_NAME=NMPL
SUPPORT_EMAIL=support@example.com
BILLING_NOTIFICATION_EMAILS=billing@example.com

ORDER_RESERVATION_EXPIRY_HOURS=48
ORDER_RESERVATION_SWEEP_SECONDS=60
REPORTS_CACHE_TTL_SECONDS=300

BANGALORE_CITY_ALIASES=BANGALORE,BENGALURU
BANGALORE_DELIVERY_CHARGE=75
PICKUP_STORE_NAME=NMPL Pickup Desk
PICKUP_STORE_PHONE=9999999999
PICKUP_STORE_LINE1=Main store
# PICKUP_STORE_LINE2=Suite 2
# PICKUP_STORE_LANDMARK=Near Metro Station
PICKUP_STORE_CITY=Bangalore
PICKUP_STORE_STATE=Karnataka
PICKUP_STORE_COUNTRY=India
PICKUP_STORE_PINCODE=560001

SMS_PROVIDER=LOG
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxx
# TWILIO_FROM_NUMBER=+919999999999

SMTP_HOST=smtp.example.com
SMTP_PASS=<smtp_password>
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<smtp_user>
EMAIL_SERVICE=smtp
EMAIL_FROM=<from_email>
EMAIL_FROM_NAME=NMPL Support

REGISTRATION_OTP_EXPIRY_SECONDS=600
REGISTRATION_OTP_RESEND_COOLDOWN_SECONDS=60
REGISTRATION_OTP_MAX_ATTEMPTS=5
REGISTRATION_PHONE_OTP_ENABLED=false

# STRIPE_SECRET_KEY=sk_live_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CURRENCY=inr
ENABLE_MOCK_PAYMENT=false

# GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxxx
GOOGLE_CALLBACK_URL_DEV=http://localhost:5001/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL_PROD=https://api.example.com/api/v1/auth/google/callback

# FACEBOOK_APP_ID=xxxx
# FACEBOOK_APP_SECRET=xxxx
FACEBOOK_CALLBACK_URL_DEV=http://localhost:5001/api/v1/auth/facebook/callback
FACEBOOK_CALLBACK_URL_PROD=https://api.example.com/api/v1/auth/facebook/callback

# TWITTER_CONSUMER_KEY=xxxx
# TWITTER_CONSUMER_SECRET=xxxx
TWITTER_CALLBACK_URL_DEV=http://localhost:5001/api/v1/auth/twitter/callback
TWITTER_CALLBACK_URL_PROD=https://api.example.com/api/v1/auth/twitter/callback

# CLOUDINARY_CLOUD_NAME=xxxx
# CLOUDINARY_API_KEY=xxxx
# CLOUDINARY_API_SECRET=xxxx

# PDF_FONT_REGULAR_PATH=assets/fonts/NotoSans-Regular.ttf
# PDF_FONT_BOLD_PATH=assets/fonts/NotoSans-Bold.ttf

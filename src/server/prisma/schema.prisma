generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl removed — only needed for Neon's pgbouncer pooled connections.
  // Railway Postgres is a plain connection; DATABASE_URL handles both queries and migrations.
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE ROLE / STATUS ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum ROLE {
  ADMIN
  USER
  DEALER
  SUPERADMIN
}

enum DEALER_STATUS {
  PENDING
  APPROVED
  LEGACY
  REJECTED
  SUSPENDED
}

enum TRANSACTION_STATUS {
  PENDING_VERIFICATION
  WAITLISTED
  AWAITING_PAYMENT
  QUOTATION_REJECTED
  QUOTATION_EXPIRED
  CONFIRMED
  DELIVERED
}

enum RESERVATION_STATUS {
  ACTIVE
  RELEASED
  EXPIRED
  CONSUMED
}

enum PAYMENT_STATUS {
  PENDING
  PAID
  CANCELED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CART_STATUS {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum CHAT_STATUS {
  OPEN
  RESOLVED
}

enum ORDER_CUSTOMER_ROLE {
  USER
  DEALER
}

enum ORDER_QUOTATION_LOG_EVENT {
  ORIGINAL_ORDER
  ADMIN_QUOTATION
  CUSTOMER_ACCEPTED
  CUSTOMER_REJECTED
  QUOTATION_EXPIRED
  PAYMENT_CONFIRMED
}

enum ADDRESS_TYPE {
  HOME
  OFFICE
  WAREHOUSE
  OTHER
}

enum DELIVERY_MODE {
  PICKUP
  DELIVERY
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT ENUMS (Phase 2 — Legacy Dealer Pay-Later)
// ─────────────────────────────────────────────────────────────────────────────

enum PAYMENT_METHOD_TYPE {
  CASH
  BANK_TRANSFER
  CHEQUE
  UPI
  NET_BANKING
  CARD
  WALLET
}

enum PAYMENT_SOURCE_TYPE {
  ADMIN_MANUAL
  GATEWAY
  MOCK_GATEWAY
}

enum PAYMENT_TXN_STATUS {
  PENDING
  CONFIRMED
  BOUNCED
  REVERSED
}

enum INVOICE_PAYMENT_STATUS {
  PAID
  PAYMENT_DUE
  OVERDUE
  SUPERSEDED
}

enum CREDIT_EVENT_TYPE {
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  ORDER_CANCELLED
  CREDIT_ADJUSTED
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                          String        @id @default(uuid())
  googleId                    String?
  twitterId                   String?
  facebookId                  String?
  email                       String        @unique
  phone                       String?
  password                    String?
  name                        String
  avatar                      String?
  tokenVersion                Int           @default(0)
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  role                        ROLE          @default(USER)
  isBillingSupervisor         Boolean       @default(false)
  mustChangePassword          Boolean       @default(false)
  orders                      Order[]
  payments                    Payment[]
  addresses                   Address[]
  interactions                Interaction[]
  reports                     Report[]
  carts                       Cart[]
  cartEvents                  CartEvent[]
  chats                       Chat[]        @relation("UserChats")
  messages                    ChatMessage[]
  dealerProfile               DealerProfile?
  dealerPriceMappings         DealerPriceMapping[]
  invoices                    Invoice[]
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  Restock                     Restock[]
  paymentTransactions         PaymentTransaction[] @relation("UserPaymentTransactions")
  recordedPayments            PaymentTransaction[] @relation("RecordedByUser")
  creditLedgerEntries         DealerCreditLedger[] @relation("DealerCreditLedger")
  paymentAuditActions         PaymentAuditLog[]    @relation("AuditActorUser")

  @@index([email])
  @@index([phone])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALER PROFILE
// ─────────────────────────────────────────────────────────────────────────────

model DealerProfile {
  id              String        @id
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String?
  contactPhone    String?
  status          DEALER_STATUS @default(PENDING)
  approvedAt      DateTime?
  approvedBy      String?
  payLaterEnabled Boolean       @default(false)
  creditTermDays  Int           @default(30)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([status])
  @@index([payLaterEnabled])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT / CATALOG
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id            String           @id @default(uuid())
  name          String           @unique
  description   String?
  slug          String           @unique
  salesCount    Int              @default(0)
  isNew         Boolean          @default(false)
  isFeatured    Boolean          @default(false)
  isTrending    Boolean          @default(false)
  isBestSeller  Boolean          @default(false)
  isDeleted     Boolean          @default(false)
  deletedAt     DateTime?
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId    String?
  variants      ProductVariant[]
  interactions  Interaction[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([name, slug])
  @@index([categoryId])
  @@index([categoryId, createdAt])
  @@index([createdAt])
  @@index([isNew, createdAt])
  @@index([isFeatured, createdAt])
  @@index([isTrending, createdAt])
  @@index([isBestSeller, createdAt])
  @@index([isDeleted])
}

model ProductVariant {
  id                  String                    @id @default(uuid())
  productId           String
  product             Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                 String                    @unique
  images              String[]                  @default([])
  price               Float
  defaultDealerPrice  Float?
  stock               Int
  reservedStock       Int                       @default(0)
  lowStockThreshold   Int                       @default(10)
  barcode             String?
  attributes          ProductVariantAttribute[]
  orderItems          OrderItem[]
  cartItems           CartItem[]
  dealerPriceMappings DealerPriceMapping[]
  stockMovements      StockMovement[]
  restocks            Restock[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([productId, sku])
  @@index([productId, price])
  @@index([productId, createdAt])
  @@index([price])
}

model DealerPriceMapping {
  id            String         @id @default(uuid())
  dealerId      String
  dealer        User           @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  customPrice   Float
  previousPrice Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([dealerId, variantId])
  @@index([dealerId])
  @@index([variantId])
}

model Attribute {
  id                String                    @id @default(uuid())
  name              String                    @unique
  slug              String                    @unique
  values            AttributeValue[]
  categories        CategoryAttribute[]
  variantAttributes ProductVariantAttribute[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([name, slug])
}

model AttributeValue {
  id                String                    @id @default(uuid())
  attributeId       String
  attribute         Attribute                 @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value             String
  slug              String                    @unique
  variantAttributes ProductVariantAttribute[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([attributeId, value])
}

model ProductVariantAttribute {
  id          String         @id @default(uuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  valueId     String
  value       AttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([variantId, attributeId, valueId])
  @@index([variantId, attributeId])
  @@index([attributeId, valueId])
}

model Category {
  id          String              @id @default(uuid())
  slug        String              @unique
  name        String
  description String?
  images      String[]
  products    Product[]
  attributes  CategoryAttribute[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([name, slug])
  @@index([createdAt])
  @@index([name])
}

model CategoryAttribute {
  id          String    @id @default(uuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  isRequired  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([categoryId, attributeId])
  @@index([categoryId, attributeId])
}

model StockMovement {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  reason    String
  userId    String?
  createdAt DateTime       @default(now())

  @@index([variantId])
}

model Restock {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  notes     String?
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([variantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                   String               @id @default(uuid())
  userId               String
  customerRoleSnapshot ORDER_CUSTOMER_ROLE  @default(USER)
  subtotalAmount       Float                @default(0)
  deliveryCharge       Float                @default(0)
  deliveryMode         DELIVERY_MODE        @default(DELIVERY)
  amount               Float
  orderDate            DateTime             @default(now())
  status               String               @default("PENDING_VERIFICATION")
  verificationQueuedAt DateTime?
  quotationSentAt      DateTime?
  paymentRequestedAt   DateTime?
  reservationExpiresAt DateTime?
  isPayLater           Boolean              @default(false)
  paymentDueDate       DateTime?
  user                 User                 @relation(fields: [userId], references: [id])
  orderItems           OrderItem[]
  payment              Payment?             @relation("OrderPayment")
  address              OrderAddressSnapshot? @relation("OrderAddress")
  transaction          Transaction?         @relation("OrderTransaction")
  reservation          OrderReservation?
  quotationLogs        OrderQuotationLog[]
  invoice              Invoice?
  paymentTransactions  PaymentTransaction[]
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
  @@index([customerRoleSnapshot])
  @@index([status])
  @@index([isPayLater])
  @@index([paymentDueDate])
  @@index([isPayLater, status, paymentDueDate])
}

model OrderQuotationLog {
  id             String                    @id @default(uuid())
  orderId        String
  order          Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event          ORDER_QUOTATION_LOG_EVENT
  previousTotal  Float?
  updatedTotal   Float
  currency       String                    @default("INR")
  actorUserId    String?
  actorRole      String?
  message        String?
  lineItems      Json?
  createdAt      DateTime                  @default(now())

  @@index([orderId, createdAt])
  @@index([event, createdAt])
}

model OrderItem {
  id        String         @id @default(uuid())
  orderId   String
  variantId String
  quantity  Int
  price     Float
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([orderId, variantId])
}

model Payment {
  id        String         @id @default(uuid())
  method    String
  amount    Float
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  order     Order?         @relation("OrderPayment", fields: [orderId], references: [id], onDelete: SetNull)
  orderId   String?        @unique
  status    PAYMENT_STATUS @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, orderId])
}

model PaymentTransaction {
  id                  String               @id @default(uuid())
  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)
  invoiceId           String?
  invoice             Invoice?             @relation("InvoicePaymentTransactions", fields: [invoiceId], references: [id], onDelete: SetNull)
  userId              String
  user                User                 @relation("UserPaymentTransactions", fields: [userId], references: [id], onDelete: Restrict)
  recordedByUserId    String?
  recordedBy          User?                @relation("RecordedByUser", fields: [recordedByUserId], references: [id], onDelete: SetNull)
  amount              Float
  paymentMethod       PAYMENT_METHOD_TYPE
  paymentSource       PAYMENT_SOURCE_TYPE  @default(ADMIN_MANUAL)
  gatewayName         String?
  gatewayOrderId      String?
  gatewayPaymentId    String?              @unique
  gatewaySignature    String?
  gatewayPayload      Json?
  utrNumber           String?
  bankName            String?
  transferDate        DateTime?
  chequeNumber        String?
  chequeDate          DateTime?
  chequeClearingDate  DateTime?
  paymentReceivedAt   DateTime
  notes               String?
  status              PAYMENT_TXN_STATUS   @default(PENDING)
  auditLogs           PaymentAuditLog[]    @relation("AuditPaymentTransaction")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([invoiceId])
  @@index([gatewayPaymentId])
  @@index([orderId, status])
  @@index([paymentMethod, paymentSource])
}

model DealerCreditLedger {
  id           String            @id @default(uuid())
  dealerId     String
  dealer       User              @relation("DealerCreditLedger", fields: [dealerId], references: [id], onDelete: Restrict)
  orderId      String?
  paymentTxnId String?
  eventType    CREDIT_EVENT_TYPE
  debitAmount  Float             @default(0)
  creditAmount Float             @default(0)
  balanceAfter Float
  notes        String?
  createdAt    DateTime          @default(now())

  @@index([dealerId])
  @@index([dealerId, createdAt])
  @@index([orderId])
  @@index([eventType])
}

model PaymentAuditLog {
  id             String              @id @default(uuid())
  orderId        String
  invoiceId      String?
  paymentTxnId   String?
  paymentTxn     PaymentTransaction? @relation("AuditPaymentTransaction", fields: [paymentTxnId], references: [id], onDelete: SetNull)
  actorUserId    String
  actorUser      User                @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: Restrict)
  actorRole      String
  action         String
  previousStatus String?
  nextStatus     String?
  metadata       Json?
  createdAt      DateTime            @default(now())

  @@index([orderId])
  @@index([actorUserId])
  @@index([action, createdAt])
  @@index([orderId, createdAt])
}

model InvoiceCounter {
  year      Int      @id
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id                  String                 @id @default(uuid())
  invoiceNumber       String                 @unique
  orderId             String                 @unique
  order               Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId              String
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerEmail       String
  paymentStatus       INVOICE_PAYMENT_STATUS @default(PAID)
  paymentTerms        String?
  paymentDueDate      DateTime?
  version             Int                    @default(1)
  isLatest            Boolean                @default(true)
  supersededById      String?
  supersededBy        Invoice?               @relation("InvoiceSupersededBy", fields: [supersededById], references: [id])
  previousVersions    Invoice[]              @relation("InvoiceSupersededBy")
  customerEmailSentAt DateTime?
  internalEmailSentAt DateTime?
  lastEmailError      String?
  paymentTransactions PaymentTransaction[]   @relation("InvoicePaymentTransactions")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([paymentStatus])
  @@index([paymentDueDate])
  @@index([isLatest, paymentStatus])
  @@index([orderId, isLatest])
}

model Transaction {
  id              String             @id @default(uuid())
  order           Order              @relation("OrderTransaction", fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String             @unique
  status          TRANSACTION_STATUS @default(PENDING_VERIFICATION)
  transactionDate DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([orderId])
}

model OrderReservation {
  id         String             @id @default(uuid())
  orderId    String             @unique
  order      Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     RESERVATION_STATUS @default(ACTIVE)
  expiresAt  DateTime
  releasedAt DateTime?
  consumedAt DateTime?
  reason     String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status, expiresAt])
}

model Address {
  id          String       @id @default(uuid())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        ADDRESS_TYPE @default(HOME)
  fullName    String
  phoneNumber String
  line1       String
  line2       String?
  landmark    String?
  city        String
  state       String
  country     String
  pincode     String
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, isDefault])
}

model OrderAddressSnapshot {
  id              String        @id @default(uuid())
  orderId         String        @unique
  order           Order         @relation("OrderAddress", fields: [orderId], references: [id], onDelete: Cascade)
  sourceAddressId String?
  addressType     ADDRESS_TYPE
  fullName        String
  phoneNumber     String
  line1           String
  line2           String?
  landmark        String?
  city            String
  state           String
  country         String
  pincode         String
  deliveryMode    DELIVERY_MODE
  deliveryCharge  Float         @default(0)
  deliveryLabel   String
  serviceArea     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([pincode])
}

model DeliveryRate {
  id            String   @id @default(uuid())
  pincode       String   @unique
  city          String?
  state         String?
  charge        Float
  isServiceable Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isServiceable])
}

model DeliveryStateRate {
  id            String   @id @default(uuid())
  state         String   @unique
  charge        Float
  isServiceable Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isServiceable])
}

model Cart {
  id         String      @id @default(uuid())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  sessionId  String?     @unique
  cartItems  CartItem[]
  cartEvents CartEvent[]
  status     CART_STATUS @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId, sessionId])
}

model CartItem {
  id        String         @id @default(uuid())
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId, variantId])
}

enum CART_EVENT {
  PENDING
  ADD
  CHECKOUT_STARTED
  CHECKOUT_COMPLETED
}

model CartEvent {
  id        String     @id @default(uuid())
  cartId    String
  userId    String?
  sessionId String?
  eventType CART_EVENT @default(PENDING)
  timestamp DateTime   @default(now())
  cart      Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())

  @@index([timestamp])
}

model Interaction {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type      String
  createdAt DateTime @default(now())

  @@index([userId, sessionId, productId])
}

model Report {
  id         String   @id @default(uuid())
  type       String
  format     String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  parameters Json
  filePath   String?

  @@index([userId])
  @@index([createdAt])
}

model Log {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AppSetting {
  key       String   @id
  value     String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

enum SECTION_TYPE {
  HERO
  PROMOTIONAL
  BENEFITS
  NEW_ARRIVALS
}

model Section {
  id             Int          @id @unique @default(autoincrement())
  type           SECTION_TYPE @default(HERO)
  title          String?
  description    String?
  images         String[]     @default([])
  icons          String?
  link           String?
  ctaText        String?
  isVisible      Boolean?     @default(false)
  primaryColor   String?
  secondaryColor String?
}

model Chat {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation("UserChats", fields: [userId], references: [id], onDelete: Cascade)
  status    CHAT_STATUS   @default(OPEN)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String?
  type      String   @default("TEXT")
  url       String?
  createdAt DateTime @default(now())

  @@index([chatId, senderId])
}

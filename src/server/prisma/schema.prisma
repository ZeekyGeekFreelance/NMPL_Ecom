generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // directUrl is only needed when DATABASE_URL points to a pgbouncer-pooled
  // connection (e.g. Neon free tier). Railway Postgres is a direct connection,
  // so directUrl is not required. If you ever switch back to a pooled provider,
  // uncomment the line below and set DIRECT_URL to the non-pooled URL.
  // directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// CORE ROLE / STATUS ENUMS
// ─────────────────────────────────────────────────────────────────────────────

enum ROLE {
  ADMIN
  USER
  DEALER
  SUPERADMIN
}

enum DEALER_STATUS {
  PENDING
  APPROVED
  LEGACY
  REJECTED
  SUSPENDED
}

enum TRANSACTION_STATUS {
  PENDING_VERIFICATION
  WAITLISTED
  AWAITING_PAYMENT
  QUOTATION_REJECTED
  QUOTATION_EXPIRED
  CONFIRMED
  DELIVERED
}

enum RESERVATION_STATUS {
  ACTIVE
  RELEASED
  EXPIRED
  CONSUMED
}

enum PAYMENT_STATUS {
  PENDING
  PAID
  CANCELED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum CART_STATUS {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum CHAT_STATUS {
  OPEN
  RESOLVED
}

enum ORDER_CUSTOMER_ROLE {
  USER
  DEALER
}

enum ORDER_QUOTATION_LOG_EVENT {
  ORIGINAL_ORDER
  ADMIN_QUOTATION
  CUSTOMER_ACCEPTED
  CUSTOMER_REJECTED
  QUOTATION_EXPIRED
  PAYMENT_CONFIRMED
}

enum ADDRESS_TYPE {
  HOME
  OFFICE
  WAREHOUSE
  OTHER
}

enum DELIVERY_MODE {
  PICKUP
  DELIVERY
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT ENUMS (Phase 2 — Legacy Dealer Pay-Later)
// ─────────────────────────────────────────────────────────────────────────────

/// All supported payment methods across offline admin recording and online gateway.
enum PAYMENT_METHOD_TYPE {
  // Offline / admin-recorded
  CASH
  BANK_TRANSFER
  CHEQUE
  // Online gateway
  UPI
  NET_BANKING
  CARD
  WALLET
}

/// Source of truth for who or what created the PaymentTransaction record.
/// ADMIN_MANUAL = admin recorded offline payment; GATEWAY = real gateway; MOCK_GATEWAY = dev only.
enum PAYMENT_SOURCE_TYPE {
  ADMIN_MANUAL
  GATEWAY
  MOCK_GATEWAY
}

/// Lifecycle of a single PaymentTransaction record.
/// PENDING = awaiting confirmation; CONFIRMED = verified; BOUNCED = cheque bounced; REVERSED = refunded.
enum PAYMENT_TXN_STATUS {
  PENDING
  CONFIRMED
  BOUNCED
  REVERSED
}

/// Payment state shown on invoice documents.
/// PAID = prepaid order; PAYMENT_DUE = pay-later awaiting; OVERDUE = deadline passed; SUPERSEDED = replaced.
enum INVOICE_PAYMENT_STATUS {
  PAID
  PAYMENT_DUE
  OVERDUE
  SUPERSEDED
}

/// Event types for the immutable credit ledger.
/// ORDER_DELIVERED = debit (dealer owes); PAYMENT_RECEIVED = credit (reduces balance); ORDER_CANCELLED = reversal; CREDIT_ADJUSTED = manual.
enum CREDIT_EVENT_TYPE {
  ORDER_DELIVERED
  PAYMENT_RECEIVED
  ORDER_CANCELLED
  CREDIT_ADJUSTED
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                          String        @id @default(uuid())
  googleId                    String?
  twitterId                   String?
  facebookId                  String?
  email                       String        @unique
  phone                       String?
  password                    String?
  name                        String
  avatar                      String?
  tokenVersion                Int           @default(0)
  resetPasswordToken          String?
  resetPasswordTokenExpiresAt DateTime?
  role                        ROLE          @default(USER)
  isBillingSupervisor         Boolean       @default(false)

  /// Forced password change on first login (used for admin-created legacy dealer accounts).
  mustChangePassword          Boolean       @default(false)

  orders                      Order[]
  payments                    Payment[]
  addresses                   Address[]
  interactions                Interaction[]
  reports                     Report[]
  carts                       Cart[]
  cartEvents                  CartEvent[]
  chats                       Chat[]        @relation("UserChats")
  messages                    ChatMessage[]
  dealerProfile               DealerProfile?
  dealerPriceMappings         DealerPriceMapping[]
  invoices                    Invoice[]
  createdAt                   DateTime      @default(now())
  updatedAt                   DateTime      @updatedAt
  Restock                     Restock[]

  /// PaymentTransactions where this user is the payer/dealer.
  paymentTransactions         PaymentTransaction[] @relation("UserPaymentTransactions")
  /// PaymentTransactions that this admin recorded.
  recordedPayments            PaymentTransaction[] @relation("RecordedByUser")
  /// Credit ledger entries for this dealer.
  creditLedgerEntries         DealerCreditLedger[] @relation("DealerCreditLedger")
  /// Audit log entries where this user was the actor.
  paymentAuditActions         PaymentAuditLog[]   @relation("AuditActorUser")

  @@index([email])
  @@index([phone])
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALER PROFILE
// ─────────────────────────────────────────────────────────────────────────────

model DealerProfile {
  id           String        @id
  userId       String        @unique
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String?
  contactPhone String?
  status       DEALER_STATUS @default(PENDING)
  approvedAt   DateTime?
  approvedBy   String?

  /// True only for LEGACY dealers.  Normal + newly-registered dealers remain false.
  payLaterEnabled Boolean  @default(false)

  /// Payment term window in days (NET 30 = 30).  Only meaningful when payLaterEnabled = true.
  creditTermDays  Int      @default(30)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status])
  // Index for fast scan of all pay-later dealers.
  @@index([payLaterEnabled])
}

// ─────────────────────────────────────────────────────────────────────────────
// PRODUCT / CATALOG
// ─────────────────────────────────────────────────────────────────────────────

model Product {
  id            String           @id @default(uuid())
  name          String           @unique
  description   String?
  slug          String           @unique
  salesCount    Int              @default(0)
  isNew         Boolean          @default(false)
  isFeatured    Boolean          @default(false)
  isTrending    Boolean          @default(false)
  isBestSeller  Boolean          @default(false)
  isDeleted     Boolean          @default(false)
  deletedAt     DateTime?
  category      Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  categoryId    String?
  variants      ProductVariant[]
  interactions  Interaction[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@index([name, slug])
  @@index([categoryId])
  @@index([categoryId, createdAt])
  @@index([createdAt])
  @@index([isNew, createdAt])
  @@index([isFeatured, createdAt])
  @@index([isTrending, createdAt])
  @@index([isBestSeller, createdAt])
  @@index([isDeleted])
}

model ProductVariant {
  id                  String                    @id @default(uuid())
  productId           String
  product             Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku                 String                    @unique
  images              String[]                  @default([])
  price               Float
  defaultDealerPrice  Float?
  stock               Int
  reservedStock       Int                       @default(0)
  lowStockThreshold   Int                       @default(10)
  barcode             String?
  attributes          ProductVariantAttribute[]
  orderItems          OrderItem[]
  cartItems           CartItem[]
  dealerPriceMappings DealerPriceMapping[]
  stockMovements      StockMovement[]
  restocks            Restock[]
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt

  @@index([productId, sku])
  @@index([productId, price])
  @@index([productId, createdAt])
  @@index([price])
}

model DealerPriceMapping {
  id            String         @id @default(uuid())
  dealerId      String
  dealer        User           @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  variantId     String
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  customPrice   Float
  previousPrice Float?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([dealerId, variantId])
  @@index([dealerId])
  @@index([variantId])
}

model Attribute {
  id                String                    @id @default(uuid())
  name              String                    @unique
  slug              String                    @unique
  values            AttributeValue[]
  categories        CategoryAttribute[]
  variantAttributes ProductVariantAttribute[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([name, slug])
}

model AttributeValue {
  id                String                    @id @default(uuid())
  attributeId       String
  attribute         Attribute                 @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value             String
  slug              String                    @unique
  variantAttributes ProductVariantAttribute[]
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  @@index([attributeId, value])
}

model ProductVariantAttribute {
  id          String         @id @default(uuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  valueId     String
  value       AttributeValue @relation(fields: [valueId], references: [id], onDelete: Cascade)
  createdAt   DateTime       @default(now())

  @@unique([variantId, attributeId, valueId])
  @@index([variantId, attributeId])
  @@index([attributeId, valueId])
}

model Category {
  id          String              @id @default(uuid())
  slug        String              @unique
  name        String
  description String?
  images      String[]
  products    Product[]
  attributes  CategoryAttribute[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([name, slug])
  @@index([createdAt])
  @@index([name])
}

model CategoryAttribute {
  id          String    @id @default(uuid())
  categoryId  String
  category    Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  isRequired  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([categoryId, attributeId])
  @@index([categoryId, attributeId])
}

model StockMovement {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  reason    String
  userId    String?
  createdAt DateTime       @default(now())

  @@index([variantId])
}

model Restock {
  id        String         @id @default(uuid())
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int
  notes     String?
  userId    String?
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime       @default(now())

  @@index([variantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                   String               @id @default(uuid())
  userId               String
  customerRoleSnapshot ORDER_CUSTOMER_ROLE  @default(USER)
  subtotalAmount       Float                @default(0)
  deliveryCharge       Float                @default(0)
  deliveryMode         DELIVERY_MODE        @default(DELIVERY)
  amount               Float
  orderDate            DateTime             @default(now())
  status               String               @default("PENDING_VERIFICATION")
  verificationQueuedAt DateTime?
  quotationSentAt      DateTime?
  paymentRequestedAt   DateTime?
  reservationExpiresAt DateTime?

  /// True when the order was placed by a pay-later legacy dealer.
  /// Snapshot of dealer's payLaterEnabled at order placement time.
  isPayLater           Boolean              @default(false)

  /// Populated at DELIVERED for pay-later orders: orderDate + creditTermDays.
  /// null for all prepaid / non-pay-later orders.
  paymentDueDate       DateTime?

  user                 User                 @relation(fields: [userId], references: [id])
  orderItems           OrderItem[]
  payment              Payment?             @relation("OrderPayment")
  address              OrderAddressSnapshot? @relation("OrderAddress")
  transaction          Transaction?         @relation("OrderTransaction")
  reservation          OrderReservation?
  quotationLogs        OrderQuotationLog[]
  invoice              Invoice?
  paymentTransactions  PaymentTransaction[]

  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  @@index([userId])
  @@index([customerRoleSnapshot])
  @@index([status])
  // Indexes for pay-later order queries and the outstanding/overdue dashboard.
  @@index([isPayLater])
  @@index([paymentDueDate])
  @@index([isPayLater, status, paymentDueDate])
}

model OrderQuotationLog {
  id             String                    @id @default(uuid())
  orderId        String
  order          Order                     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event          ORDER_QUOTATION_LOG_EVENT
  previousTotal  Float?
  updatedTotal   Float
  currency       String                    @default("INR")
  actorUserId    String?
  actorRole      String?
  message        String?
  lineItems      Json?
  createdAt      DateTime                  @default(now())

  @@index([orderId, createdAt])
  @@index([event, createdAt])
}

model OrderItem {
  id        String         @id @default(uuid())
  orderId   String
  variantId String
  quantity  Int
  price     Float
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([orderId, variantId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT (legacy thin record — retained for backward compatibility)
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id        String         @id @default(uuid())
  method    String
  amount    Float
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  order     Order?         @relation("OrderPayment", fields: [orderId], references: [id], onDelete: SetNull)
  orderId   String?        @unique
  status    PAYMENT_STATUS @default(PENDING)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@index([userId, orderId])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT TRANSACTION  (Phase 2 — full audit-grade payment record)
// ─────────────────────────────────────────────────────────────────────────────

/// Full payment record for every real money movement — offline or gateway.
/// Replaces the thin Payment model for new pay-later and gateway flows.
/// The legacy Payment record is still updated for backward compatibility.
model PaymentTransaction {
  id                  String               @id @default(uuid())

  orderId             String
  order               Order                @relation(fields: [orderId], references: [id], onDelete: Restrict)

  /// The active invoice at time of payment recording.  Null if invoice not yet generated.
  invoiceId           String?
  invoice             Invoice?             @relation("InvoicePaymentTransactions", fields: [invoiceId], references: [id], onDelete: SetNull)

  /// The dealer or customer who made/owes the payment.
  userId              String
  user                User                 @relation("UserPaymentTransactions", fields: [userId], references: [id], onDelete: Restrict)

  /// Admin who recorded the payment (null for gateway-initiated payments).
  recordedByUserId    String?
  recordedBy          User?                @relation("RecordedByUser", fields: [recordedByUserId], references: [id], onDelete: SetNull)

  amount              Float
  paymentMethod       PAYMENT_METHOD_TYPE
  paymentSource       PAYMENT_SOURCE_TYPE  @default(ADMIN_MANUAL)

  // ── Online gateway fields ──────────────────────────────────────────────────
  gatewayName         String?              // "Razorpay" | "Stripe"
  gatewayOrderId      String?              // Gateway's order ID
  gatewayPaymentId    String?              @unique  // Gateway's payment ID — unique prevents duplicate capture
  gatewaySignature    String?              // HMAC signature for verification
  gatewayPayload      Json?                // Full gateway webhook payload (stored securely)

  // ── Bank transfer fields ───────────────────────────────────────────────────
  utrNumber           String?              // UTR / IMPS / NEFT reference
  bankName            String?
  transferDate        DateTime?

  // ── Cheque fields ──────────────────────────────────────────────────────────
  chequeNumber        String?
  chequeDate          DateTime?
  chequeClearingDate  DateTime?

  // ── Cash fields ───────────────────────────────────────────────────────────
  // paymentReceivedAt is used for cash received date

  paymentReceivedAt   DateTime             // When payment was physically received / gateway confirmed
  notes               String?

  status              PAYMENT_TXN_STATUS   @default(PENDING)

  auditLogs           PaymentAuditLog[]    @relation("AuditPaymentTransaction")

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@index([invoiceId])
  @@index([gatewayPaymentId])                     // fast idempotency lookup
  @@index([orderId, status])                      // double-payment guard query
  @@index([paymentMethod, paymentSource])         // admin payment type reports
}

// ─────────────────────────────────────────────────────────────────────────────
// DEALER CREDIT LEDGER  (Phase 2 — running balance of outstanding credit)
// ─────────────────────────────────────────────────────────────────────────────

/// Double-entry-style ledger that tracks each dealer's outstanding balance.
/// Every delivered pay-later order creates a DEBIT entry.
/// Every recorded payment creates a CREDIT entry.
/// Running balance = SUM(debitAmount) - SUM(creditAmount) per dealer.
model DealerCreditLedger {
  id             String            @id @default(uuid())

  dealerId       String
  dealer         User              @relation("DealerCreditLedger", fields: [dealerId], references: [id], onDelete: Restrict)

  orderId        String?           // linked order (ORDER_DELIVERED / ORDER_CANCELLED)
  paymentTxnId   String?           // linked payment (PAYMENT_RECEIVED)

  eventType      CREDIT_EVENT_TYPE

  /// Amount charged to the dealer (order delivered = dealer owes this).
  debitAmount    Float             @default(0)

  /// Amount credited to the dealer (payment received = reduces outstanding).
  creditAmount   Float             @default(0)

  /// Running balance AFTER this event.  Positive = dealer owes money.
  balanceAfter   Float

  notes          String?
  createdAt      DateTime          @default(now())

  @@index([dealerId])
  @@index([dealerId, createdAt])   // chronological ledger per dealer
  @@index([orderId])
  @@index([eventType])
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT AUDIT LOG  (Phase 2 — immutable audit trail)
// ─────────────────────────────────────────────────────────────────────────────

/// Immutable append-only log of every payment-related action.
/// Never updated or deleted — admin actions, gateway events, invoice regenerations.
model PaymentAuditLog {
  id             String    @id @default(uuid())

  orderId        String
  invoiceId      String?

  /// The PaymentTransaction this audit event relates to (null for non-payment events).
  paymentTxnId   String?
  paymentTxn     PaymentTransaction? @relation("AuditPaymentTransaction", fields: [paymentTxnId], references: [id], onDelete: SetNull)

  /// The user who performed the action (admin, system, dealer).
  actorUserId    String
  actorUser      User     @relation("AuditActorUser", fields: [actorUserId], references: [id], onDelete: Restrict)

  actorRole      String

  /// Structured action label.
  /// Examples: ADMIN_MARKED_CASH | ADMIN_MARKED_BANK_TRANSFER | ADMIN_MARKED_CHEQUE
  ///           GATEWAY_PAYMENT_CONFIRMED | INVOICE_REGENERATED | PAYMENT_BOUNCED
  ///           CREDIT_LEDGER_UPDATED | DOUBLE_PAYMENT_BLOCKED
  action         String

  previousStatus String?
  nextStatus     String?

  /// Extra context (gateway payload summary, reference numbers, etc.)
  metadata       Json?

  createdAt      DateTime @default(now())

  @@index([orderId])
  @@index([actorUserId])
  @@index([action, createdAt])     // audit trail report by action type
  @@index([orderId, createdAt])    // full history for one order
}

// ─────────────────────────────────────────────────────────────────────────────
// INVOICE  (modified — Phase 2 adds payment-aware fields + versioning)
// ─────────────────────────────────────────────────────────────────────────────

model InvoiceCounter {
  year      Int      @id
  sequence  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id                  String                 @id @default(uuid())
  invoiceNumber       String                 @unique
  orderId             String                 @unique
  order               Order                  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId              String
  user                User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerEmail       String

  // ── Payment state on the invoice document ─────────────────────────────────
  /// PAID for standard prepaid orders.
  /// PAYMENT_DUE for pay-later orders awaiting payment.
  /// OVERDUE computed by background job when paymentDueDate has passed.
  /// SUPERSEDED when a newer invoice version exists after payment recording.
  paymentStatus       INVOICE_PAYMENT_STATUS @default(PAID)

  /// e.g. "NET 30 DAYS" — populated for pay-later invoices.
  paymentTerms        String?

  /// Copied from Order.paymentDueDate.  Used for overdue calculation and display.
  paymentDueDate      DateTime?

  // ── Invoice versioning (regeneration after payment) ───────────────────────
  /// Starts at 1.  Incremented each time the invoice is superseded.
  version             Int                    @default(1)

  /// Only the latest version is served via download endpoints.
  /// Old versions are archived (isLatest = false).
  isLatest            Boolean                @default(true)

  /// Points to the newer invoice that superseded this one.
  /// null on the current active invoice.
  supersededById      String?
  supersededBy        Invoice?               @relation("InvoiceSupersededBy", fields: [supersededById], references: [id])
  previousVersions    Invoice[]              @relation("InvoiceSupersededBy")

  // ── Email tracking ─────────────────────────────────────────────────────────
  customerEmailSentAt DateTime?
  internalEmailSentAt DateTime?
  lastEmailError      String?

  paymentTransactions PaymentTransaction[]   @relation("InvoicePaymentTransactions")

  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([paymentStatus])                    // outstanding invoice queries
  @@index([paymentDueDate])                   // overdue sweep
  @@index([isLatest, paymentStatus])          // admin outstanding view: isLatest=true AND paymentStatus IN (PAYMENT_DUE, OVERDUE)
  @@index([orderId, isLatest])                // latest invoice for an order
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSACTION / RESERVATION
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id              String             @id @default(uuid())
  order           Order              @relation("OrderTransaction", fields: [orderId], references: [id], onDelete: Cascade)
  orderId         String             @unique
  status          TRANSACTION_STATUS @default(PENDING_VERIFICATION)
  transactionDate DateTime           @default(now())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([orderId])
}

model OrderReservation {
  id         String             @id @default(uuid())
  orderId    String             @unique
  order      Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     RESERVATION_STATUS @default(ACTIVE)
  expiresAt  DateTime
  releasedAt DateTime?
  consumedAt DateTime?
  reason     String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([status, expiresAt])
}

// ─────────────────────────────────────────────────────────────────────────────
// ADDRESS
// ─────────────────────────────────────────────────────────────────────────────

model Address {
  id          String       @id @default(uuid())
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  type        ADDRESS_TYPE @default(HOME)
  fullName    String
  phoneNumber String
  line1       String
  line2       String?
  landmark    String?
  city        String
  state       String
  country     String
  pincode     String
  isDefault   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([userId, isDefault])
}

model OrderAddressSnapshot {
  id              String        @id @default(uuid())
  orderId         String        @unique
  order           Order         @relation("OrderAddress", fields: [orderId], references: [id], onDelete: Cascade)
  sourceAddressId String?
  addressType     ADDRESS_TYPE
  fullName        String
  phoneNumber     String
  line1           String
  line2           String?
  landmark        String?
  city            String
  state           String
  country         String
  pincode         String
  deliveryMode    DELIVERY_MODE
  deliveryCharge  Float         @default(0)
  deliveryLabel   String
  serviceArea     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([pincode])
}

// ─────────────────────────────────────────────────────────────────────────────
// DELIVERY
// ─────────────────────────────────────────────────────────────────────────────

model DeliveryRate {
  id            String   @id @default(uuid())
  pincode       String   @unique
  city          String?
  state         String?
  charge        Float
  isServiceable Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isServiceable])
}

model DeliveryStateRate {
  id            String   @id @default(uuid())
  state         String   @unique
  charge        Float
  isServiceable Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isServiceable])
}

// ─────────────────────────────────────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────────────────────────────────────

model Cart {
  id         String      @id @default(uuid())
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  sessionId  String?     @unique
  cartItems  CartItem[]
  cartEvents CartEvent[]
  status     CART_STATUS @default(ACTIVE)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@index([userId, sessionId])
}

model CartItem {
  id        String         @id @default(uuid())
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  cartId    String
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  quantity  Int            @default(1)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@unique([cartId, variantId])
  @@index([cartId, variantId])
}

enum CART_EVENT {
  PENDING
  ADD
  CHECKOUT_STARTED
  CHECKOUT_COMPLETED
}

model CartEvent {
  id        String     @id @default(uuid())
  cartId    String
  userId    String?
  sessionId String?
  eventType CART_EVENT @default(PENDING)
  timestamp DateTime   @default(now())
  cart      Cart       @relation(fields: [cartId], references: [id], onDelete: Cascade)
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())

  @@index([timestamp])
}

// ─────────────────────────────────────────────────────────────────────────────
// ANALYTICS / ADMIN
// ─────────────────────────────────────────────────────────────────────────────

model Interaction {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId String?
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  type      String
  createdAt DateTime @default(now())

  @@index([userId, sessionId, productId])
}

model Report {
  id         String   @id @default(uuid())
  type       String
  format     String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  parameters Json
  filePath   String?

  @@index([userId])
  @@index([createdAt])
}

model Log {
  id        String   @id @default(uuid())
  level     String
  message   String
  context   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AppSetting {
  key       String   @id
  value     String
  updatedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}

enum SECTION_TYPE {
  HERO
  PROMOTIONAL
  BENEFITS
  NEW_ARRIVALS
}

model Section {
  id             Int          @id @unique @default(autoincrement())
  type           SECTION_TYPE @default(HERO)
  title          String?
  description    String?
  images         String[]     @default([])
  icons          String?
  link           String?
  ctaText        String?
  isVisible      Boolean?     @default(false)
  primaryColor   String?
  secondaryColor String?
}

// ─────────────────────────────────────────────────────────────────────────────
// CHAT
// ─────────────────────────────────────────────────────────────────────────────

model Chat {
  id        String        @id @default(uuid())
  userId    String
  user      User          @relation("UserChats", fields: [userId], references: [id], onDelete: Cascade)
  status    CHAT_STATUS   @default(OPEN)
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId])
}

model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  content   String?
  type      String   @default("TEXT")
  url       String?
  createdAt DateTime @default(now())

  @@index([chatId, senderId])
}

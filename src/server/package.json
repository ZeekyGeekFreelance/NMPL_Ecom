{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "resolutions": {
    "@types/express": "4.17.21",
    "xmldom": "npm:@xmldom/xmldom@^0.9.6"
  },
  "overrides": {
    "@ngneat/falso": {
      "uuid": "^9.0.1"

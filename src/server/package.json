  "scripts": {
    "dev": "prisma generate && nodemon",
    "repo:sanity": "node ./scripts/repo-sanity-proxy.js",
    "env:check": "ts-node --transpile-only -r dotenv/config src/config/index.ts",
    "build": "npm run repo:sanity && npm run env:check && node ./scripts/clean-build.js && node ./scripts/assert-determinism.js pre && tsc && node ./scripts/assert-determinism.js post",
    "start": "node -r ./scripts/load-env.js -r module-alias/register dist/server.js",
    "prisma": "prisma",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "seed": "ts-node seeds/seed.ts",
    "data:normalize:titlecase": "ts-node scripts/normalize-title-case-data.ts",
    "test:cleanup": "node -r ./scripts/load-env.js -r module-alias/register -r ts-node/register test-cleanup.ts"
  },
  "engines": {
    "node": ">=22 <23"
  },

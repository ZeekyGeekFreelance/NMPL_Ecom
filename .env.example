# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/nmpl?schema=public&sslmode=disable"
DIRECT_URL="postgresql://user:password@localhost:5432/nmpl?schema=public&sslmode=disable"

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PLATFORM_NAME="NMPL"
NEXT_PUBLIC_SUPPORT_EMAIL="support@nmpl.online"

# ─── Auth Secrets (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
ACCESS_TOKEN_SECRET="replace_with_64_char_hex"
REFRESH_TOKEN_SECRET="replace_with_64_char_hex"
COOKIE_SECRET="replace_with_32_char_hex"

# ─── Token TTLs ───────────────────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_ABS_TTL_SECONDS=86400

# ─── Cookie ───────────────────────────────────────────────────────────────────
COOKIE_DOMAIN=localhost
COOKIE_SAMESITE=lax

# ─── Email (Nodemailer) ───────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=yourpassword
EMAIL_FROM="NMPL <noreply@nmpl.online>"
BILLING_NOTIFICATION_EMAILS=billing@nmpl.online

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Business Logic ───────────────────────────────────────────────────────────
BANGALORE_DELIVERY_CHARGE=75
PICKUP_STORE_NAME="NMPL Pickup Desk"
PICKUP_STORE_PHONE=9999999999
PLATFORM_NAME=NMPL
SUPPORT_EMAIL=support@nmpl.online

# ─── Dev Flags ────────────────────────────────────────────────────────────────
ENABLE_MOCK_PAYMENT=false
